# Backend Configuration
PORT=5000

# PostgreSQL Connection URL
# Recommended: connect with a read-only database user for safety (e.g. pg_read_all_data)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Local AI Server FastAPI Endpoints
LLM_SERVER_URL=http://localhost:8000
EMBEDDING_SERVER_URL=http://localhost:8001
RERANKER_SERVER_URL=http://localhost:8002

# Local Qdrant Server Endpoint
QDRANT_URL=http://localhost:6333

